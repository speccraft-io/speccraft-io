---
// Giscus comments — GitHub Discussions as the backend (pseudonymous: commenters
// post under their GitHub handle). No server to run; moderation is done in the
// speccraft-io/speccraft-io repo's Discussions tab (hide / delete / lock / block).
// To change repo/category IDs, regenerate at https://giscus.app.
---

<section class="comments" aria-label="Comments">
	<script
		is:inline
		src="https://giscus.app/client.js"
		data-repo="speccraft-io/speccraft-io"
		data-repo-id="R_kgDOTJvNzA"
		data-category="Announcements"
		data-category-id="DIC_kwDOTJvNzM4DAYs7"
		data-mapping="pathname"
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="bottom"
		data-theme="preferred_color_scheme"
		data-lang="en"
		crossorigin="anonymous"
		async></script>
</section>
