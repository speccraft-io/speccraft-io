---
// Giscus comments — GitHub Discussions as the backend (pseudonymous: commenters
// post under their GitHub handle). No server to run; moderation is done in the
// repo's Discussions tab (hide / delete / lock / block user).
//
// SETUP (one-time) — replace the four REPLACE_ME values below:
//   1. Make sure a PUBLIC repo has Discussions enabled
//      (Settings → General → Features → Discussions). Default: speccraft-io/speccraft-io.
//   2. Install the giscus GitHub App on that repo: https://github.com/apps/giscus
//   3. Go to https://giscus.app, enter the repo + pick a Discussion category
//      (e.g. "Comments", ideally an "Announcement"-type category so only
//      maintainers open threads and giscus creates them on demand).
//   4. Copy `data-repo-id` and `data-category-id` from the generated snippet
//      into repoId / categoryId here.
const repo = 'speccraft-io/speccraft-io';
const repoId = 'REPLACE_ME_REPO_ID';
const category = 'Comments';
const categoryId = 'REPLACE_ME_CATEGORY_ID';

// Don't render a broken widget in production: only mount once real IDs are set.
const configured = !repoId.startsWith('REPLACE_ME') && !categoryId.startsWith('REPLACE_ME');
---

{configured && (
<section class="comments" aria-label="Comments">
	<script
		is:inline
		src="https://giscus.app/client.js"
		data-repo={repo}
		data-repo-id={repoId}
		data-category={category}
		data-category-id={categoryId}
		data-mapping="pathname"
		data-strict="1"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="top"
		data-theme="preferred_color_scheme"
		data-lang="en"
		crossorigin="anonymous"
		async></script>
</section>
)}
